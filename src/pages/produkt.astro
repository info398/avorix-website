---
import BaseLayout from "../layouts/BaseLayout.astro";
import { useTranslations } from "../i18n/translations";

const t = useTranslations("de");

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Avorix Koch App",
  "alternateName": "Avorix Küchenmanagement",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web, iOS, Android",
  "description": "Die Avorix Koch App führt Ihr Küchenteam Schritt für Schritt durch jedes Rezept — mit Fotos, Mengenangaben und Zeittakten. Für 4-Sterne-Ferienhotels mit Halbpension.",
  "url": "https://avorix.cloud/produkt",
  "inLanguage": "de",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "description": "Pilotprogramm für Hotels — kostenlose Testphase"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Avorix",
    "url": "https://avorix.cloud"
  },
  "featureList": [
    "Schritt-für-Schritt Rezeptführung mit Fotos",
    "Automatische Mengenanpassung",
    "Offline-Nutzung in der Küche",
    "Echtzeit-Qualitätskontrolle"
  ]
};
---

<BaseLayout
  title="Produkt — Avorix Koch App"
  description="Die Avorix Koch App führt Ihr Küchenteam Schritt für Schritt durch jedes Rezept — mit Fotos, Mengenangaben und Zeittakten. Für 4-Sterne-Ferienhotels mit Halbpension."
  schemaOrg={schema}
>
  <!-- Hero -->
  <section class="pt-32 pb-20 px-6 bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 bg-brand-100 text-brand-700 text-xs font-semibold px-3 py-1 rounded-full mb-6">
        <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
        {t("produkt.badge")}
      </span>
      <h1 class="text-4xl md:text-6xl font-bold text-avorix-dark mb-6 leading-tight">
        {t("produkt.tagline")}
      </h1>
      <p class="text-xl text-avorix-gray leading-relaxed max-w-2xl mx-auto mb-10">
        {t("produkt.subtitle")}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="/kontakt"
          class="inline-block bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors"
        >
          {t("produkt.cta.primary")}
        </a>
        <a
          href="/koch-app"
          class="inline-block border border-brand-300 text-brand-600 px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-50 transition-colors"
        >
          {t("produkt.cta.secondary")}
        </a>
      </div>
      <p class="text-sm text-avorix-silver mt-4">{t("produkt.cta.note")}</p>
    </div>
  </section>

  <!-- Target Audience -->
  <section class="py-20 px-6 bg-avorix-dark">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-white mb-6">{t("produkt.target.title")}</h2>
          <p class="text-avorix-silver leading-relaxed text-lg">{t("produkt.target.text")}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-6">
          <div class="bg-white/5 rounded-xl p-6 border border-white/10">
            <div class="text-4xl font-bold text-brand-400 mb-2">{t("produkt.target.stat1.number")}</div>
            <div class="text-avorix-silver text-sm leading-relaxed">{t("produkt.target.stat1.label")}</div>
          </div>
          <div class="bg-white/5 rounded-xl p-6 border border-white/10">
            <div class="text-4xl font-bold text-brand-400 mb-2">{t("produkt.target.stat2.number")}</div>
            <div class="text-avorix-silver text-sm leading-relaxed">{t("produkt.target.stat2.label")}</div>
          </div>
          <div class="bg-white/5 rounded-xl p-6 border border-white/10">
            <div class="text-4xl font-bold text-brand-400 mb-2">{t("produkt.target.stat3.number")}</div>
            <div class="text-avorix-silver text-sm leading-relaxed">{t("produkt.target.stat3.label")}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works (visual workflow) -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-avorix-dark text-center mb-16">{t("produkt.workflow.title")}</h2>
      <div class="relative">
        <!-- Connector line (desktop) -->
        <div class="hidden md:block absolute top-10 left-1/6 right-1/6 h-0.5 bg-brand-100"></div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <div class="relative text-center">
            <div class="w-20 h-20 bg-brand-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
              <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-avorix-dark mb-3">{t("produkt.workflow.step1.title")}</h3>
            <p class="text-avorix-gray leading-relaxed">{t("produkt.workflow.step1.text")}</p>
          </div>
          <div class="relative text-center">
            <div class="w-20 h-20 bg-brand-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
              <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-avorix-dark mb-3">{t("produkt.workflow.step2.title")}</h3>
            <p class="text-avorix-gray leading-relaxed">{t("produkt.workflow.step2.text")}</p>
          </div>
          <div class="relative text-center">
            <div class="w-20 h-20 bg-brand-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
              <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-avorix-dark mb-3">{t("produkt.workflow.step3.title")}</h3>
            <p class="text-avorix-gray leading-relaxed">{t("produkt.workflow.step3.text")}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 px-6 bg-neutral-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-avorix-dark text-center mb-14">{t("produkt.features.title")}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-7 border border-avorix-light hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-avorix-dark mb-2">{t("produkt.features.1.title")}</h3>
          <p class="text-avorix-gray text-sm leading-relaxed">{t("produkt.features.1.text")}</p>
        </div>
        <div class="bg-white rounded-xl p-7 border border-avorix-light hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-avorix-dark mb-2">{t("produkt.features.2.title")}</h3>
          <p class="text-avorix-gray text-sm leading-relaxed">{t("produkt.features.2.text")}</p>
        </div>
        <div class="bg-white rounded-xl p-7 border border-avorix-light hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-avorix-dark mb-2">{t("produkt.features.3.title")}</h3>
          <p class="text-avorix-gray text-sm leading-relaxed">{t("produkt.features.3.text")}</p>
        </div>
        <div class="bg-white rounded-xl p-7 border border-avorix-light hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-avorix-dark mb-2">{t("produkt.features.4.title")}</h3>
          <p class="text-avorix-gray text-sm leading-relaxed">{t("produkt.features.4.text")}</p>
        </div>
        <div class="bg-white rounded-xl p-7 border border-avorix-light hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728M15.536 8.464a5 5 0 010 7.072M6.343 6.343a9 9 0 000 12.728m2.829-2.829a5 5 0 000-7.07" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-avorix-dark mb-2">{t("produkt.features.5.title")}</h3>
          <p class="text-avorix-gray text-sm leading-relaxed">{t("produkt.features.5.text")}</p>
        </div>
        <div class="bg-white rounded-xl p-7 border border-avorix-light hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-avorix-dark mb-2">{t("produkt.features.6.title")}</h3>
          <p class="text-avorix-gray text-sm leading-relaxed">{t("produkt.features.6.text")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Development status / Pilot CTA -->
  <section class="py-20 px-6 bg-brand-50 border-t border-brand-100">
    <div class="max-w-3xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 bg-white border border-brand-200 text-brand-700 text-xs font-semibold px-3 py-1 rounded-full mb-6">
        <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
        {t("produkt.dev.title")}
      </span>
      <h2 class="text-3xl font-bold text-avorix-dark mb-5">{t("produkt.cta.section.title")}</h2>
      <p class="text-lg text-avorix-gray mb-8 leading-relaxed">{t("produkt.cta.section.text")}</p>
      <ul class="flex flex-col sm:flex-row gap-4 justify-center mb-10 text-sm text-avorix-gray">
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          {t("produkt.dev.benefit1")}
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          {t("produkt.dev.benefit2")}
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          {t("produkt.dev.benefit3")}
        </li>
      </ul>
      <a
        href="/kontakt"
        class="inline-block bg-brand-500 text-white px-10 py-4 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors shadow-lg shadow-brand-200"
      >
        {t("produkt.cta.primary")}
      </a>
      <p class="text-sm text-avorix-silver mt-4">{t("produkt.cta.note")}</p>
    </div>
  </section>
</BaseLayout>
