---
import BaseLayout from "../layouts/BaseLayout.astro";
import { useTranslations } from "../i18n/translations";

const t = useTranslations("de");
---

<BaseLayout title="\u00dcber uns" description="Avorix — Küchenmanagement für Ferienhotels in Tirol und Salzburg. Wir helfen Betrieben, trotz Fachkräftemangel konstante Speisenqualität zu liefern.">
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold text-avorix-dark mb-6">{t("about.title")}</h1>
      <p class="text-lg text-avorix-gray leading-relaxed mb-12">
        {t("about.intro")}
      </p>

      <div class="space-y-12">
        <div>
          <h2 class="text-2xl font-semibold text-avorix-dark mb-4">{t("about.mission.title")}</h2>
          <p class="text-avorix-gray leading-relaxed">
            {t("about.mission.text")}
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-avorix-dark mb-4">{t("about.focus.title")}</h2>
          <p class="text-avorix-gray leading-relaxed">
            {t("about.focus.text")}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
