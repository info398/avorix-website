---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/translations";

const t = useTranslations("en");

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Book a Demo — Avorix",
  "description": "Contact Avorix for a demo or more information about our Kitchen App and kitchen management software for hotels and restaurants.",
  "url": "https://avorix.cloud/en/contact",
  "inLanguage": "en",
  "mainEntity": {
    "@type": "Organization",
    "name": "Avorix",
    "url": "https://avorix.cloud",
    "email": "info@avorix.de",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "info@avorix.de",
      "contactType": "sales",
      "availableLanguage": ["German", "English"]
    }
  }
};
---

<BaseLayout title="Book a Demo" description="Contact Avorix for a demo or more information about our Kitchen App and kitchen management software for hotels and restaurants." schemaOrg={schema}>
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">{t("contact.eyebrow")}</p>
      <h1 class="text-4xl font-bold text-avorix-dark mb-4">{t("contact.title")}</h1>
      <p class="text-lg text-avorix-gray mb-10">{t("contact.intro")}</p>

      <!-- Calendly Booking Widget -->
      <div class="bg-brand-50 border border-brand-100 rounded-2xl p-8 mb-12 text-center">
        <h2 class="text-xl font-semibold text-avorix-dark mb-2">{t("contact.booking.heading")}</h2>
        <p class="text-avorix-gray mb-6">{t("contact.booking.text")}</p>
        <a
          href="https://calendly.com/avorix/kostenfreies-erstgesprach"
          target="_blank"
          rel="noopener"
          class="inline-block bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors"
        >
          {t("contact.booking.button")}
        </a>
        <p class="text-sm text-avorix-silver mt-3">{t("contact.booking.note")}</p>
      </div>

      <p class="text-sm font-semibold text-avorix-dark uppercase tracking-wider mb-8">{t("contact.or")}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="space-y-6">
          <div>
            <h3 class="text-sm font-semibold text-avorix-dark mb-1">{t("contact.email")}</h3>
            <a href="mailto:info@avorix.de" class="text-avorix-gray hover:text-avorix-dark transition-colors">
              info@avorix.de
            </a>
          </div>
        </div>

        <form class="space-y-4" action="https://formspree.io/f/xqegwngo" method="POST">
          <input type="hidden" name="_subject" value="Demo request via avorix.cloud" />
          <div>
            <label for="name" class="block text-sm font-medium text-avorix-dark mb-1">
              {t("contact.form.name")}
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-avorix-dark mb-1">
              {t("contact.form.email")}
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-avorix-dark mb-1">
              {t("contact.form.message")}
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-brand-500 text-white px-8 py-3 rounded-lg text-sm font-semibold hover:bg-brand-600 active:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 transition-colors w-full"
          >
            {t("contact.form.submit")}
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

