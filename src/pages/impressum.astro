---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Impressum" description="Impressum der Avorix GmbH">
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto prose prose-gray">
      <h1 class="text-4xl font-bold text-avorix-dark mb-8">Impressum</h1>

      <h2 class="text-xl font-semibold text-avorix-dark mt-8 mb-3">Angaben gem\u00e4\u00df \u00a7 5 TMG</h2>
      <p class="text-avorix-gray">
        Avorix GmbH<br />
        <!-- TODO: Echte Adresse eintragen -->
        Musterstra\u00dfe 1<br />
        10115 Berlin
      </p>

      <h2 class="text-xl font-semibold text-avorix-dark mt-8 mb-3">Vertreten durch</h2>
      <p class="text-avorix-gray">
        Gesch\u00e4ftsf\u00fchrer: Uwe Schmitz
      </p>

      <h2 class="text-xl font-semibold text-avorix-dark mt-8 mb-3">Kontakt</h2>
      <p class="text-avorix-gray">
        E-Mail: <a href="mailto:info@avorix.cloud" class="text-avorix-dark hover:underline">info@avorix.cloud</a><br />
        Telefon: +49 151 5817 6124
      </p>

      <h2 class="text-xl font-semibold text-avorix-dark mt-8 mb-3">Registereintrag</h2>
      <p class="text-avorix-gray">
        <!-- TODO: Echte Registerdaten eintragen -->
        Eintragung im Handelsregister.<br />
        Registergericht: Amtsgericht Berlin-Charlottenburg<br />
        Registernummer: HRB XXXXX
      </p>

      <h2 class="text-xl font-semibold text-avorix-dark mt-8 mb-3">Umsatzsteuer-ID</h2>
      <p class="text-avorix-gray">
        <!-- TODO: Echte USt-ID eintragen -->
        Umsatzsteuer-Identifikationsnummer gem\u00e4\u00df \u00a7 27a Umsatzsteuergesetz:<br />
        DE XXXXXXXXX
      </p>

      <h2 class="text-xl font-semibold text-avorix-dark mt-8 mb-3">Verantwortlich f\u00fcr den Inhalt nach \u00a7 55 Abs. 2 RSt V</h2>
      <p class="text-avorix-gray">
        Uwe Schmitz<br />
        <!-- TODO: Echte Adresse eintragen -->
        Musterstra\u00dfe 1<br />
        10115 Berlin
      </p>

      <h2 class="text-xl font-semibold text-avorix-dark mt-8 mb-3">Streitschlichtung</h2>
      <p class="text-avorix-gray">
        Die Europ\u00e4ische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
        <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener" class="text-avorix-dark hover:underline">
          https://ec.europa.eu/consumers/odr/
        </a>.<br />
        Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer
        Verbraucherschlichtungsstelle teilzunehmen.
      </p>
    </div>
  </section>
</BaseLayout>
