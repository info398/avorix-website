---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/translations";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="fixed top-0 w-full bg-white/95 backdrop-blur-sm border-b border-brand-100 z-50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={getLocalizedPath("/", lang)} class="flex items-center gap-3">
      <img src="/logo-dark.jpg" alt="Avorix" class="h-9 rounded" />
      <span class="text-xl font-semibold tracking-tight text-brand-600">AVORIX</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href={getLocalizedPath("/", lang)} class="text-avorix-gray hover:text-avorix-dark transition-colors text-sm font-medium">
        {t("nav.home")}
      </a>
      <a href={getLocalizedPath(lang === "de" ? "/ueber-uns" : "/about", lang)} class="text-avorix-gray hover:text-avorix-dark transition-colors text-sm font-medium">
        {t("nav.about")}
      </a>
      <a href={getLocalizedPath(lang === "de" ? "/kontakt" : "/contact", lang)} class="bg-brand-500 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-brand-600 transition-colors">
        {t("nav.contact")}
      </a>
      <LanguageSwitcher />
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-avorix-light bg-white">
    <div class="px-6 py-4 flex flex-col gap-4">
      <a href={getLocalizedPath("/", lang)} class="text-avorix-gray hover:text-avorix-dark text-sm font-medium">
        {t("nav.home")}
      </a>
      <a href={getLocalizedPath(lang === "de" ? "/ueber-uns" : "/about", lang)} class="text-avorix-gray hover:text-avorix-dark text-sm font-medium">
        {t("nav.about")}
      </a>
      <a href={getLocalizedPath(lang === "de" ? "/kontakt" : "/contact", lang)} class="text-avorix-gray hover:text-avorix-dark text-sm font-medium">
        {t("nav.contact")}
      </a>
      <LanguageSwitcher />
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
