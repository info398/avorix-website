---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 px-6 bg-avorix-dark text-white">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-4">{t("cta.title")}</h2>
    <p class="text-avorix-silver text-lg mb-8">{t("cta.text")}</p>
    <a
      href={getLocalizedPath(lang === "de" ? "/kontakt" : "/contact", lang)}
      class="inline-block border border-white/20 text-white px-8 py-3 rounded-lg text-sm font-semibold hover:bg-white/10 hover:border-white/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900 transition-colors"
    >
      {t("cta.button")}
    </a>
  </div>
</section>
