---
import { getLangFromUrl, languages } from "../i18n/translations";

const lang = getLangFromUrl(Astro.url);
const otherLang = lang === "de" ? "en" : "de";

// Map current path to equivalent in other language
const pathname = Astro.url.pathname;
let otherPath: string;

if (lang === "de") {
  // DE -> EN
  if (pathname === "/" || pathname === "") otherPath = "/en";
  else if (pathname === "/ueber-uns") otherPath = "/en/about";
  else if (pathname === "/kontakt") otherPath = "/en/contact";
  else if (pathname === "/impressum") otherPath = "/en/legal-notice";
  else if (pathname === "/datenschutz") otherPath = "/en/privacy";
  else otherPath = `/en${pathname}`;
} else {
  // EN -> DE
  if (pathname === "/en" || pathname === "/en/") otherPath = "/";
  else if (pathname === "/en/about") otherPath = "/ueber-uns";
  else if (pathname === "/en/contact") otherPath = "/kontakt";
  else if (pathname === "/en/legal-notice") otherPath = "/impressum";
  else if (pathname === "/en/privacy") otherPath = "/datenschutz";
  else otherPath = pathname.replace(/^\/en/, "");
}
---

<a
  href={otherPath}
  class="text-sm font-medium text-avorix-silver hover:text-avorix-dark transition-colors border border-avorix-light rounded-md px-3 py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
>
  {languages[otherLang]}
</a>
