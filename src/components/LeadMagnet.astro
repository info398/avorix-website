---
import { getLangFromUrl, getLocalizedPath } from "../i18n/translations";

const lang = getLangFromUrl(Astro.url);
const leitfadenPath = getLocalizedPath("/leitfaden", lang);
---

<section class="py-16 px-6 bg-gradient-to-br from-brand-50 to-white border-y border-brand-100">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col md:flex-row items-center gap-8">

      <!-- Icon / Visual -->
      <div class="flex-shrink-0">
        <div class="w-20 h-20 bg-brand-600 rounded-2xl flex items-center justify-center shadow-lg">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
      </div>

      <!-- Text -->
      <div class="flex-1 text-center md:text-left">
        <span class="inline-block text-xs font-semibold text-brand-600 uppercase tracking-widest mb-1">
          Kostenloser Leitfaden
        </span>
        <h2 class="text-2xl font-bold text-avorix-dark mb-2">
          5 Strategien gegen den Fachkräftemangel in der Küche
        </h2>
        <p class="text-avorix-gray text-sm max-w-lg">
          Praxisnaher Leitfaden für Hoteliers und Küchenchefs — mit konkreten Massnahmen, die Sie sofort umsetzen können.
        </p>
      </div>

      <!-- CTA -->
      <div class="flex-shrink-0 text-center">
        <a
          href={leitfadenPath}
          class="inline-flex items-center gap-2 bg-brand-600 text-white px-6 py-3 rounded-lg font-semibold text-sm hover:bg-brand-700 active:bg-brand-800 transition-colors shadow-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Jetzt kostenlos herunterladen
        </a>
        <p class="text-xs text-avorix-silver mt-2">PDF, kein Spam</p>
      </div>

    </div>
  </div>
</section>
